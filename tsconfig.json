{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./src/.dumi/*"],
      "rc-collapse": ["./src/index.tsx"]
    },
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "strictFunctionTypes": false,
    "strict": false,
    "noImplicitThis": false,
    "strictBindCallApply": false,
    "module": "ESNext"
  },
  "include": [
    "global.d.ts",
    ".fatherrc.ts",
    ".dumirc.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./tests/**/*.ts",
    "./tests/**/*.tsx",
    "./docs/**/*.tsx"
  ]
}
