{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "node",
    "baseUrl": "./",
    "jsx": "react",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@@/*": [
        "src/.dumi/*"
      ],
      "rc-collapse": [
        "src/index.tsx"
      ]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [
    ".fatherrc.ts",
    ".dumirc.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./tests/**/*.ts",
    "./tests/**/*.tsx",
    "./docs/**/*.tsx"
  ]
}
